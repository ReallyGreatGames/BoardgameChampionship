# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit actual paths/secrets

# Android SDK path (required for running on Android device/emulator)
# Windows example: C:\Users\yourname\AppData\Local\Android\Sdk
# macOS example:   /Users/yourname/Library/Android/sdk
ANDROID_HOME=
EXPO_PUBLIC_APPWRITE_PROJECT_ID=
EXPO_PUBLIC_APPWRITE_PROJECT_NAME=
EXPO_PUBLIC_APPWRITE_ENDPOINT=
EXPO_PUBLIC_APPWRITE_DATABASE_ID=